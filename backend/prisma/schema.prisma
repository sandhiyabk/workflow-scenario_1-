generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workflow {
  id           String      @id @default(uuid())
  name         String
  version      Int         @default(1)
  is_active    Boolean     @default(true)
  input_schema Json
  start_step_id String?
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt
  steps        Step[]
  executions   Execution[]
}

model Step {
  id          String   @id @default(uuid())
  workflow    Workflow @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  workflow_id String
  name        String
  step_type   String
  order       Int
  metadata    Json
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  rules       Rule[]

  @@index([workflow_id])
}

model Rule {
  id           String   @id @default(uuid())
  step         Step     @relation(fields: [step_id], references: [id], onDelete: Cascade)
  step_id      String
  condition    String
  next_step_id String?
  priority     Int      @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([step_id])
}

model Execution {
  id               String          @id @default(uuid())
  workflow         Workflow        @relation(fields: [workflow_id], references: [id])
  workflow_id      String
  workflow_version Int
  status           String          @default("PENDING")
  data             Json
  active_step_ids  Json            @default("[]") // Replaces current_step_id for parallel support
  retries          Int             @default(0)
  triggered_by     String?
  started_at       DateTime        @default(now())
  ended_at         DateTime?
  logs             ExecutionLog[]

  @@index([workflow_id])
}

model ExecutionLog {
  id                String    @id @default(uuid())
  execution         Execution @relation(fields: [execution_id], references: [id], onDelete: Cascade)
  execution_id      String
  step_name         String
  step_type         String
  evaluated_rules   Json
  selected_next_step String?
  status            String
  approver_id       String?
  error_message     String?
  metadata          Json?
  started_at        DateTime  @default(now())
  ended_at          DateTime?

  @@index([execution_id])
}
